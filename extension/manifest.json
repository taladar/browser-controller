{
  "manifest_version": 3,
  "name": "Browser Controller",
  "version": "0.2.1",
  "description": "Native messaging bridge for browser-controller CLI",
  "background": {
    "service_worker": "background.js",
    "scripts": [
      "background.js"
    ]
  },
  "permissions": [
    "contextualIdentities",
    "cookies",
    "nativeMessaging",
    "scripting",
    "sessions",
    "downloads",
    "tabs",
    "webRequest",
    "webRequestBlocking"
  ],
  "incognito": "spanning",
  "host_permissions": [
    "<all_urls>"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "browser-controller@taladar.net",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
