{
  "manifest_version": 3,
  "name": "Browser Controller",
  "version": "0.1.3",
  "description": "Native messaging bridge for browser-controller CLI",
  "background": {
    "service_worker": "background.js",
    "scripts": [
      "background.js"
    ]
  },
  "permissions": [
    "nativeMessaging",
    "scripting",
    "sessions",
    "tabs",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "browser-controller@taladar.net",
      "strict_min_version": "109.0"
    }
  }
}
