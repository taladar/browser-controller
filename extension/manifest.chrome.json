{
  "manifest_version": 3,
  "name": "Browser Controller",
  "version": "0.1.5",
  "description": "Native messaging bridge for browser-controller CLI",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "alarms",
    "nativeMessaging",
    "offscreen",
    "scripting",
    "downloads",
    "tabs",
    "tabGroups",
    "webRequest",
    "webRequestAuthProvider"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
